<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:designvm="using:Clever.TokenMap.App.Design"
        xmlns:vm="using:Clever.TokenMap.App.ViewModels"
        xmlns:views="using:Clever.TokenMap.App.Views"
        xmlns:sections="using:Clever.TokenMap.App.Views.Sections"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="Clever.TokenMap.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Width="1600"
        Height="1000"
        MinWidth="1100"
        MinHeight="650"
        Background="{DynamicResource TokenMapAppBackgroundBrush}"
        Foreground="{DynamicResource TokenMapTextBrush}"
        d:DesignWidth="1600"
        d:DesignHeight="1000"
        mc:Ignorable="d"
        Icon="avares://Clever.TokenMap.App/Assets/app-icon.ico"
        Title="{Binding WindowTitle}">
    <Design.DataContext>
        <designvm:MainWindowDesignViewModel />
    </Design.DataContext>

    <Window.Styles>
        <StyleInclude Source="avares://Clever.TokenMap.App/Views/Styles/MainWindowStyles.axaml" />
    </Window.Styles>

        <Grid RowDefinitions="Auto,*,Auto"
              Margin="10">
        <sections:ToolbarSummaryView Grid.Row="0" />

        <Grid Grid.Row="1">
            <Grid Name="WorkspaceHost"
                  Margin="0,10,0,8"
                  ColumnDefinitions="2*,10,3*">
                <sections:ProjectTreePaneView Grid.Column="0" />
                <GridSplitter Grid.Column="1"
                              ResizeDirection="Columns"
                              Background="{DynamicResource TokenMapDividerBrush}" />
                <sections:TreemapPaneView Grid.Column="2" />
            </Grid>

            <Border Name="RecentFoldersStartSurface"
                    Classes="panel"
                    Margin="0,10,0,8"
                    Padding="24"
                    ZIndex="{x:Static views:MainWindowZLayers.StartSurface}"
                    IsVisible="{Binding RecentFolders.ShowStartSurface}">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="18">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <TextBlock Classes="panel-title"
                                   VerticalAlignment="Center"
                                   Text="Previous folders" />
                        <Button Name="ClearRecentFoldersButton"
                                Grid.Column="1"
                                Classes="recent-clear-button"
                                VerticalAlignment="Center"
                                IsVisible="{Binding RecentFolders.HasRecentFolders}"
                                Command="{Binding RecentFolders.ClearRecentFoldersCommand}"
                                Content="Clear" />
                    </Grid>

                    <StackPanel Name="RecentFoldersEmptyState"
                                Grid.Row="1"
                                MaxWidth="360"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8"
                                IsVisible="{Binding RecentFolders.ShowEmptyState}">
                        <TextBlock Classes="panel-title"
                                   HorizontalAlignment="Center"
                                   Text="No previous folders yet" />
                        <Button Name="RecentFoldersEmptyStateOpenButton"
                                Classes="action-button primary"
                                HorizontalAlignment="Center"
                                Command="{Binding Toolbar.OpenFolderCommand}">
                            <StackPanel Classes="action-button-content">
                                <Path Classes="action-button-icon"
                                      Data="{StaticResource FluentFolderOpen20RegularGeometry}" />
                                <TextBlock VerticalAlignment="Center"
                                           Text="Open Folder" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding RecentFolders.HasRecentFolders}">
                        <ItemsControl Name="RecentFoldersItemsControl"
                                      ItemsSource="{Binding RecentFolders.Items}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"
                                               ItemWidth="360" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RecentFolderItemViewModel">
                                    <Grid Classes="recent-folder-tile"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,10,10">
                                        <Button Classes="recent-folder-button"
                                                HorizontalAlignment="Stretch"
                                                Margin="0"
                                                Padding="14,13,40,13"
                                                Command="{Binding DataContext.RecentFolders.OpenRecentFolderCommand, ElementName=RootWindow}"
                                                CommandParameter="{Binding}">
                                            <Grid RowDefinitions="Auto,Auto"
                                                  ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="16"
                                                  RowSpacing="6">
                                                <Border Grid.RowSpan="2"
                                                        Classes="recent-folder-icon-host">
                                                    <Path Classes="recent-folder-icon"
                                                          Data="{StaticResource FluentFolderOpen20RegularGeometry}" />
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="8">
                                                    <TextBlock Classes="recent-folder-title"
                                                               Text="{Binding DisplayName}" />
                                                    <Border Classes="recent-folder-status-badge"
                                                            IsVisible="{Binding IsMissing}">
                                                        <TextBlock Classes="recent-folder-status-text"
                                                                   Text="Missing" />
                                                    </Border>
                                                </StackPanel>

                                                <TextBlock Grid.Row="1"
                                                           Grid.Column="1"
                                                           Classes="recent-folder-path"
                                                           Text="{Binding SecondaryText}" />
                                            </Grid>
                                        </Button>
                                        <Button Classes="close-button recent-folder-remove-button"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Command="{Binding DataContext.RecentFolders.RemoveRecentFolderCommand, ElementName=RootWindow}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Remove from recent folders">
                                            <Path Classes="close-button-icon"
                                                  Data="{StaticResource FluentDismiss20Geometry}" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>

        <Border Name="SettingsBackdrop"
                Grid.RowSpan="3"
                Background="Transparent"
                IsVisible="{Binding IsSettingsOpen}"
                PointerPressed="SettingsBackdrop_OnPointerPressed"
                ZIndex="{x:Static views:MainWindowZLayers.SettingsBackdrop}" />

        <sections:SettingsDrawerView Name="SettingsDrawerHost"
                                     Grid.Row="1"
                                     ZIndex="{x:Static views:MainWindowZLayers.SettingsDrawer}" />

        <Border Name="ProgressStatusPill"
                Grid.RowSpan="3"
                Classes="progress-status-pill"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,18"
                IsHitTestVisible="False"
                IsVisible="{Binding Summary.IsProgressPillVisible}"
                ZIndex="{x:Static views:MainWindowZLayers.ProgressPill}">
            <TextBlock Name="ProgressStatusPillText"
                       Classes="progress-status-pill-text"
                       Text="{Binding Summary.ProgressPillText}" />
        </Border>

        <Border Name="AppIssueBanner"
                Grid.RowSpan="3"
                Classes="panel issue-banner"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,18,0,0"
                MaxWidth="720"
                IsVisible="{Binding Issue.IsBannerVisible}"
                ZIndex="{x:Static views:MainWindowZLayers.IssueBanner}">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Name="AppIssueBannerTitleText"
                               Classes="issue-title"
                               Text="{Binding Issue.Title}" />
                    <TextBlock Name="AppIssueBannerMessageText"
                               Classes="issue-body"
                               Text="{Binding Issue.Message}" />
                    <TextBlock Name="AppIssueBannerReferenceText"
                               Classes="issue-meta"
                               Text="{Binding Issue.ReferenceIdText}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Spacing="8">
                    <Button Name="AppIssueBannerOpenLogsButton"
                            Classes="action-button"
                            Command="{Binding Issue.OpenLogsCommand}"
                            Content="Open Logs" />
                    <Button Name="AppIssueBannerDismissButton"
                            Classes="action-button"
                            Command="{Binding Issue.DismissCommand}"
                            Content="Dismiss" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Name="AppIssueBackdrop"
                Grid.RowSpan="3"
                Background="#7A0B1016"
                IsVisible="{Binding Issue.IsModalVisible}"
                ZIndex="{x:Static views:MainWindowZLayers.IssueBackdrop}" />

        <Border Name="AppIssueModal"
                Grid.RowSpan="3"
                Classes="panel issue-modal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="520"
                MaxWidth="520"
                IsVisible="{Binding Issue.IsModalVisible}"
                ZIndex="{x:Static views:MainWindowZLayers.IssueModal}">
            <StackPanel Spacing="12">
                <TextBlock Name="AppIssueModalTitleText"
                           Classes="panel-title issue-title"
                           Text="{Binding Issue.Title}" />
                <TextBlock Name="AppIssueModalMessageText"
                           Classes="issue-body"
                           Text="{Binding Issue.Message}" />
                <TextBlock Name="AppIssueModalReferenceText"
                           Classes="issue-meta"
                           Text="{Binding Issue.ReferenceIdText}" />
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8">
                    <Button Name="AppIssueModalOpenLogsButton"
                            Classes="action-button"
                            Command="{Binding Issue.OpenLogsCommand}"
                            Content="Open Logs" />
                    <Button Name="AppIssueModalCloseAppButton"
                            Classes="action-button primary"
                            Command="{Binding Issue.CloseAppCommand}"
                            Content="Close App" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Name="ExcludesEditorBackdrop"
                Grid.RowSpan="3"
                Background="#660B1016"
                IsVisible="{Binding ExcludesEditor.IsOpen}"
                ZIndex="{x:Static views:MainWindowZLayers.ExcludesBackdrop}" />

        <views:ExcludesEditorModalView Name="ExcludesEditorModal"
                                       Grid.RowSpan="3"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding ExcludesEditor.IsOpen}"
                                       ZIndex="{x:Static views:MainWindowZLayers.ExcludesModal}" />

        <Border Name="ShareSnapshotBackdrop"
                Grid.RowSpan="3"
                Background="#660B1016"
                IsVisible="{Binding IsShareSnapshotOpen}"
                ZIndex="{x:Static views:MainWindowZLayers.ShareBackdrop}" />

        <views:ShareSnapshotModalView Name="ShareSnapshotModal"
                                      Grid.RowSpan="3"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsVisible="{Binding IsShareSnapshotOpen}"
                                      ZIndex="{x:Static views:MainWindowZLayers.ShareModal}" />

        <Border Name="StatusStrip"
                Grid.Row="2"
                IsVisible="{Binding Summary.IsProgressVisible}">
            <ProgressBar Name="StatusProgressBar"
                         Foreground="{DynamicResource TokenMapAccentBrush}"
                         Height="4"
                         Minimum="0"
                         Maximum="100"
                         IsIndeterminate="{Binding Summary.IsProgressIndeterminate}"
                         Value="{Binding Summary.ProgressValue}" />
        </Border>
    </Grid>
</Window>
