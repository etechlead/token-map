<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Clever.TokenMap.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="Clever.TokenMap.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1440"
        Height="860"
        MinWidth="1100"
        MinHeight="650"
        d:DesignWidth="1440"
        d:DesignHeight="860"
        mc:Ignorable="d"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="BorderBrush" Value="#2E3A46" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#111722" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style Selector="TextBlock.panel-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F5F7FA" />
        </Style>
        <Style Selector="TextBlock.panel-body">
            <Setter Property="Foreground" Value="#B7C2CC" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          Margin="18">
        <Border Name="ToolbarHost"
                Grid.Row="0"
                Classes="panel"
                Padding="14">
            <Grid ColumnDefinitions="Auto,Auto,Auto,16*,Auto,Auto,Auto">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <Button Name="OpenFolderButton"
                            Content="Open Folder"
                            Command="{Binding Toolbar.OpenFolderCommand}" />
                    <Button Name="RescanButton"
                            Content="Rescan"
                            Command="{Binding Toolbar.RescanCommand}" />
                    <Button Name="CancelButton"
                            Content="Cancel"
                            Command="{Binding Toolbar.CancelCommand}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        Width="1"
                        Height="28"
                        Background="#2E3A46" />

                <StackPanel Grid.Column="2"
                            Margin="16,0,0,0"
                            VerticalAlignment="Center"
                            Spacing="4">
                    <TextBlock Foreground="#8FA3B8"
                               FontSize="11"
                               Text="Selected folder" />
                    <TextBlock FontSize="13"
                               FontWeight="Medium"
                               Text="{Binding Toolbar.SelectedFolderDisplay}" />
                </StackPanel>

                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="12">
                    <StackPanel Width="150"
                                Spacing="4">
                        <TextBlock Foreground="#8FA3B8"
                                   FontSize="11"
                                   Text="Treemap metric" />
                        <ComboBox ItemsSource="{Binding Toolbar.MetricOptions}"
                                  SelectedItem="{Binding Toolbar.SelectedMetric}"
                                  IsEnabled="{Binding Toolbar.CanChangeOptions}" />
                    </StackPanel>

                    <StackPanel Width="150"
                                Spacing="4">
                        <TextBlock Foreground="#8FA3B8"
                                   FontSize="11"
                                   Text="Tokenizer" />
                        <ComboBox ItemsSource="{Binding Toolbar.TokenProfiles}"
                                  SelectedItem="{Binding Toolbar.SelectedTokenProfile}"
                                  IsEnabled="{Binding Toolbar.CanChangeOptions}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="5"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Spacing="4">
                    <CheckBox Content="Respect .gitignore"
                              IsChecked="{Binding Toolbar.RespectGitIgnore}"
                              IsEnabled="{Binding Toolbar.CanChangeOptions}" />
                    <CheckBox Content="Respect .ignore"
                              IsChecked="{Binding Toolbar.RespectIgnore}"
                              IsEnabled="{Binding Toolbar.CanChangeOptions}" />
                </StackPanel>

                <CheckBox Grid.Column="6"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"
                          Content="Use default excludes"
                          IsChecked="{Binding Toolbar.UseDefaultExcludes}"
                          IsEnabled="{Binding Toolbar.CanChangeOptions}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,16,0,16"
              ColumnDefinitions="300,10,*,10,340">
            <Border Name="ProjectTreePane"
                    Grid.Column="0"
                    Classes="panel">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <TextBlock Classes="panel-title"
                               Text="Project Tree" />
                    <TreeView Name="ProjectTreeControl"
                              Grid.Row="1"
                              ItemsSource="{Binding Tree.RootNodes}"
                              SelectedItem="{Binding Tree.SelectedNode, Mode=TwoWay}">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate x:DataType="vm:ProjectTreeNodeViewModel"
                                              ItemsSource="{Binding Children}">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock Grid.Column="1"
                                               Foreground="#8FA3B8"
                                               Text="{Binding SecondaryText}" />
                                </Grid>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          ResizeDirection="Columns"
                          Background="#2E3A46" />

            <Border Name="TreemapPane"
                    Grid.Column="2"
                    Classes="panel">
                <Grid RowDefinitions="Auto,Auto,*"
                      RowSpacing="12">
                    <TextBlock Classes="panel-title"
                               Text="Treemap" />
                    <TextBlock Classes="panel-body"
                               Text="{Binding Summary.SummaryText}" />
                    <TextBlock Grid.Row="1"
                               Classes="panel-body"
                               Foreground="#8FA3B8"
                               Text="{Binding Summary.TotalsText}" />
                    <Border Grid.Row="2"
                            Background="#0B1018"
                            BorderBrush="#233041"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="10">
                            <TextBlock Classes="panel-body"
                                       HorizontalAlignment="Center"
                                       Text="Treemap custom control will be added in a dedicated stage." />
                            <TextBlock Name="ProgressTextBlock"
                                       Classes="panel-body"
                                       HorizontalAlignment="Center"
                                       Foreground="#8FA3B8"
                                       Text="{Binding Summary.ProgressText}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3"
                          ResizeDirection="Columns"
                          Background="#2E3A46" />

            <Border Name="DetailsPane"
                    Grid.Column="4"
                    Classes="panel">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <TextBlock Classes="panel-title"
                               Text="Details" />
                    <StackPanel Grid.Row="1"
                                Spacing="8">
                        <TextBlock Name="DetailsSelectionTitle"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="{Binding Details.SelectionTitle}" />
                        <TextBlock Name="DetailsPathText"
                                   Classes="panel-body"
                                   Text="{Binding Details.PathText}" />
                        <TextBlock Classes="panel-body"
                                   Text="{Binding Details.KindText}" />
                        <TextBlock Classes="panel-body"
                                   Text="{Binding Details.TokensText}" />
                        <TextBlock Classes="panel-body"
                                   Text="{Binding Details.LinesText}" />
                        <TextBlock Classes="panel-body"
                                   Text="{Binding Details.LanguageText}" />
                        <TextBlock Classes="panel-body"
                                   Text="{Binding Details.SizeText}" />
                        <TextBlock Classes="panel-body"
                                   Text="{Binding Details.DiagnosticsText}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Name="StatusStrip"
                Grid.Row="2"
                Classes="panel"
                Padding="12">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Foreground="#8FA3B8"
                           FontSize="12"
                           Text="Status" />
                <TextBlock Name="StatusValueText"
                           Grid.Column="1"
                           Margin="10,0,0,0"
                           FontSize="12"
                           Text="{Binding Summary.StatusText}" />
            </Grid>
        </Border>
    </Grid>
</Window>
