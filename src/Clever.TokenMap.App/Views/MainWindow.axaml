<Window xmlns="https://github.com/avaloniaui"
        xmlns:controls="using:Clever.TokenMap.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Clever.TokenMap.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="Clever.TokenMap.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1440"
        Height="860"
        MinWidth="1100"
        MinHeight="650"
        d:DesignWidth="1440"
        d:DesignHeight="860"
        mc:Ignorable="d"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="BorderBrush" Value="#2E3A46" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#111722" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style Selector="TextBlock.panel-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#F5F7FA" />
        </Style>
        <Style Selector="TextBlock.panel-body">
            <Setter Property="Foreground" Value="#B7C2CC" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="Border.summary-card">
            <Setter Property="Background" Value="#162131" />
            <Setter Property="BorderBrush" Value="#233041" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="Border.toolbar-group">
            <Setter Property="Background" Value="#0F1621" />
            <Setter Property="BorderBrush" Value="#233041" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
        <Style Selector="TextBlock.toolbar-group-title">
            <Setter Property="Foreground" Value="#8FA3B8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.summary-label">
            <Setter Property="Foreground" Value="#8FA3B8" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style Selector="TextBlock.summary-value">
            <Setter Property="Foreground" Value="#F5F7FA" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.tree-expander">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#162131" />
            <Setter Property="BorderBrush" Value="#233041" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
        </Style>
        <Style Selector="TextBlock.tree-table-name">
            <Setter Property="Foreground" Value="#F5F7FA" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          Margin="18">
        <Border Name="ToolbarHost"
                Grid.Row="0"
                Classes="panel"
                Padding="14">
            <Grid>
                <StackPanel HorizontalAlignment="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="18">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <Button Name="OpenFolderButton"
                                Content="Open Folder"
                                Command="{Binding Toolbar.OpenFolderCommand}" />
                        <Button Name="RescanButton"
                                Content="Rescan"
                                Command="{Binding Toolbar.RescanCommand}" />
                        <Button Name="CancelButton"
                                Content="Cancel"
                                Command="{Binding Toolbar.CancelCommand}" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Center"
                                Spacing="2">
                        <TextBlock Foreground="#8FA3B8"
                                   FontSize="11"
                                   Text="Selected folder" />
                        <TextBlock FontSize="13"
                                   FontWeight="Medium"
                                   Text="{Binding Toolbar.SelectedFolderDisplay}" />
                    </StackPanel>
                </StackPanel>

                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      ColumnDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="10">
                    <Border Classes="summary-card"
                            MinWidth="120">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="summary-label"
                                       Text="Tokens" />
                            <TextBlock Name="TokenSummaryValueText"
                                       Classes="summary-value"
                                       Text="{Binding Summary.TokenSummaryValue}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            Classes="summary-card"
                            MinWidth="120">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="summary-label"
                                       Text="Lines" />
                            <TextBlock Name="LineSummaryValueText"
                                       Classes="summary-value"
                                       Text="{Binding Summary.LineSummaryValue}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2"
                            Classes="summary-card"
                            MinWidth="120">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="summary-label"
                                       Text="Files" />
                            <TextBlock Name="FileSummaryValueText"
                                       Classes="summary-value"
                                       Text="{Binding Summary.FileSummaryValue}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="16">
                    <Border Classes="toolbar-group">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="toolbar-group-title"
                                       Text="View settings" />
                            <StackPanel Width="120"
                                        Spacing="4">
                                <TextBlock Foreground="#8FA3B8"
                                           FontSize="11"
                                           Text="Treemap metric" />
                                <ComboBox Name="MetricComboBox"
                                          ItemsSource="{Binding Toolbar.MetricOptions}"
                                          SelectedItem="{Binding Toolbar.SelectedMetric}"
                                          IsEnabled="{Binding Toolbar.CanChangeMetric}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Classes="toolbar-group">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="toolbar-group-title"
                                       Text="Scan settings" />
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Spacing="14">
                                <StackPanel Width="120"
                                            Spacing="4">
                                    <TextBlock Foreground="#8FA3B8"
                                               FontSize="11"
                                               Text="Tokenizer" />
                                    <ComboBox Name="TokenizerComboBox"
                                              ItemsSource="{Binding Toolbar.TokenProfiles}"
                                              SelectedItem="{Binding Toolbar.SelectedTokenProfile}"
                                              IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                                </StackPanel>

                                <CheckBox Name="RespectGitIgnoreCheckBox"
                                          VerticalAlignment="Center"
                                          Content="Respect .gitignore"
                                          IsChecked="{Binding Toolbar.RespectGitIgnore}"
                                          IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                                <CheckBox Name="RespectIgnoreCheckBox"
                                          VerticalAlignment="Center"
                                          Content="Respect .ignore"
                                          IsChecked="{Binding Toolbar.RespectIgnore}"
                                          IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                                <CheckBox Name="UseDefaultExcludesCheckBox"
                                          VerticalAlignment="Center"
                                          Content="Use default excludes"
                                          IsChecked="{Binding Toolbar.UseDefaultExcludes}"
                                          IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Name="WorkspaceHost"
              Grid.Row="1"
              Margin="0,16,0,16"
              ColumnDefinitions="2*,10,3*">
            <Border Name="ProjectTreePane"
                    Grid.Column="0"
                    Classes="panel">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <TextBlock Classes="panel-title"
                               Text="Project Tree" />
                    <DataGrid Name="ProjectTreeTable"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding Tree.VisibleNodes}"
                              SelectedItem="{Binding Tree.SelectedNode, Mode=TwoWay}"
                              DoubleTapped="ProjectTreeTable_OnDoubleTapped"
                              PointerPressed="ProjectTreeTable_OnPointerPressed">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Name"
                                                    SortMemberPath="Name"
                                                    Width="3*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="vm:ProjectTreeNodeViewModel">
                                        <Grid Margin="{Binding IndentMargin}"
                                              ColumnDefinitions="18,*"
                                              ColumnSpacing="6">
                                            <Button Grid.Column="0"
                                                    Classes="tree-expander"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Click="ProjectTreeExpandCollapseButton_OnClick"
                                                    IsVisible="{Binding HasChildren}">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="10"
                                                           Foreground="#D6E3F0"
                                                           Text="{Binding ExpanderGlyph}" />
                                            </Button>
                                            <TextBlock Grid.Column="1"
                                                       Classes="tree-table-name"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Name}" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Size"
                                                SortMemberPath="Size"
                                                Binding="{Binding SizeText}"
                                                Width="110" />
                            <DataGridTextColumn Header="Lines"
                                                SortMemberPath="Lines"
                                                Binding="{Binding TotalLinesText}"
                                                Width="90" />
                            <DataGridTextColumn Header="Tokens"
                                                SortMemberPath="Tokens"
                                                Binding="{Binding TokensText}"
                                                Width="110" />
                            <DataGridTextColumn Header="Files"
                                                SortMemberPath="Files"
                                                Binding="{Binding FilesText}"
                                                Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          ResizeDirection="Columns"
                          Background="#2E3A46" />

            <Border Name="TreemapPane"
                    Grid.Column="2"
                    Classes="panel">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="12">
                        <TextBlock Classes="panel-title"
                                   VerticalAlignment="Center"
                                   Text="Treemap" />
                        <TextBlock Name="TreemapScopeText"
                                   Grid.Column="1"
                                   IsVisible="{Binding CanShowTreemapScope}"
                                   VerticalAlignment="Center"
                                   Foreground="#8FA3B8"
                                   FontSize="11"
                                   Text="{Binding TreemapScopeDisplay}" />
                        <Button Name="TreemapBackToOverviewButton"
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Content="Back to Root"
                                Command="{Binding ResetTreemapRootCommand}"
                                IsVisible="{Binding CanResetTreemapRoot}" />
                    </Grid>
                    <Border Grid.Row="1"
                            Background="#0B1018"
                            BorderBrush="#233041"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="8">
                        <controls:TreemapControl Name="ProjectTreemapControl"
                                                 RootNode="{Binding TreemapRootNode}"
                                                 Metric="{Binding Toolbar.SelectedMetric}"
                                                 SelectedNode="{Binding SelectedNode, Mode=TwoWay}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Name="StatusStrip"
                Grid.Row="2"
                IsVisible="{Binding Summary.IsProgressVisible}">
            <ProgressBar Name="StatusProgressBar"
                         Height="4"
                         Minimum="0"
                         Maximum="100"
                         IsIndeterminate="{Binding Summary.IsProgressIndeterminate}"
                         Value="{Binding Summary.ProgressValue}" />
        </Border>
    </Grid>
</Window>
