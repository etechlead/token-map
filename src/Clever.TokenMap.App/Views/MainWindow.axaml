<Window xmlns="https://github.com/avaloniaui"
        xmlns:controls="using:Clever.TokenMap.Controls"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Clever.TokenMap.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="Clever.TokenMap.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="RootWindow"
        Width="1440"
        Height="860"
        MinWidth="1100"
        MinHeight="650"
        Background="{DynamicResource TokenMapAppBackgroundBrush}"
        Foreground="{DynamicResource TokenMapTextBrush}"
        d:DesignWidth="1440"
        d:DesignHeight="860"
        mc:Ignorable="d"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="{DynamicResource TokenMapSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="TextBlock.panel-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="TextBlock.panel-body">
            <Setter Property="Foreground" Value="{DynamicResource TokenMapMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="Border.summary-card">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Border.toolbar-group">
            <Setter Property="Background" Value="{DynamicResource TokenMapSurfaceSubtleBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style Selector="TextBlock.toolbar-group-title">
            <Setter Property="Foreground" Value="{DynamicResource TokenMapMutedTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.summary-label">
            <Setter Property="Foreground" Value="{DynamicResource TokenMapMutedTextBrush}" />
            <Setter Property="FontSize" Value="10" />
        </Style>
        <Style Selector="TextBlock.summary-value">
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.tree-expander">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="Path.tree-expander-chevron">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Stroke" Value="{DynamicResource TokenMapMutedTextBrush}" />
            <Setter Property="StrokeThickness" Value="1.6" />
            <Setter Property="StrokeLineCap" Value="Round" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="Button.action-button">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Setter Property="Background" Value="{DynamicResource TokenMapSurfaceSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TokenMapBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.action-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource TokenMapControlHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TokenMapControlHoverBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="Button.action-button:pressed">
            <Setter Property="Background" Value="{DynamicResource TokenMapSurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TokenMapAccentPressedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="Button.action-button.primary">
            <Setter Property="Background" Value="{DynamicResource TokenMapAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TokenMapAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.action-button.primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource TokenMapAccentHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TokenMapAccentHoverBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.action-button.primary:pressed">
            <Setter Property="Background" Value="{DynamicResource TokenMapAccentPressedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TokenMapAccentPressedBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.action-button:disabled">
            <Setter Property="Opacity" Value="0.55" />
        </Style>
        <Style Selector="TextBlock.tree-table-name">
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style Selector="TextBlock.tree-table-number">
            <Setter Property="Foreground" Value="{DynamicResource TokenMapSecondaryTextBrush}" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>
        <Style Selector="svg|Svg.tree-file-icon">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
        </Style>
        <Style Selector="DataGrid#ProjectTreeTable">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource TokenMapDividerBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        </Style>
        <Style Selector="DataGrid#ProjectTreeTable DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="{DynamicResource TokenMapDividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style Selector="DataGrid#ProjectTreeTable DataGridColumnHeader:pointerover">
            <Setter Property="Background" Value="{DynamicResource TokenMapSurfaceSubtleBrush}" />
        </Style>
        <Style Selector="DataGrid#ProjectTreeTable DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style Selector="DataGrid#ProjectTreeTable DataGridCell:current">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="DataGrid#ProjectTreeTable DataGridCell:selected">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="DataGrid#ProjectTreeTable DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="DataGrid#ProjectTreeTable DataGridRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource TokenMapSurfaceSubtleBrush}" />
        </Style>
        <Style Selector="DataGrid#ProjectTreeTable DataGridRow:selected">
            <Setter Property="Background" Value="{DynamicResource TokenMapAccentSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="Border.settings-drawer">
            <Setter Property="Width" Value="320" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="BorderBrush" Value="{DynamicResource TokenMapDividerBrush}" />
            <Setter Property="BorderThickness" Value="1,0,0,0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="Button.breadcrumb-link">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapMutedTextBrush}" />
        </Style>
        <Style Selector="Button.breadcrumb-link:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TokenMapAccentBrush}" />
        </Style>
        <Style Selector="TextBlock.breadcrumb-current">
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
        <Style Selector="Button.close-button">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapMutedTextBrush}" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.close-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource TokenMapSurfaceSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="Button.close-button:pressed">
            <Setter Property="Background" Value="{DynamicResource TokenMapSurfaceMutedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="Path.close-button-icon">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Stroke" Value="{DynamicResource TokenMapMutedTextBrush}" />
            <Setter Property="StrokeThickness" Value="1.6" />
            <Setter Property="StrokeLineCap" Value="Round" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="Button.close-button:pointerover Path.close-button-icon">
            <Setter Property="Stroke" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="Button.close-button:pressed Path.close-button-icon">
            <Setter Property="Stroke" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="BorderBrush" Value="{DynamicResource TokenMapBorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource TokenMapSurfaceBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource TokenMapControlHoverBorderBrush}" />
        </Style>
        <Style Selector="ComboBox /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource TokenMapSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource TokenMapSurfaceSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="ComboBoxItem:selected">
            <Setter Property="Background" Value="{DynamicResource TokenMapAccentSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="Border.theme-switcher-panel">
            <Setter Property="Background" Value="{DynamicResource TokenMapSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TokenMapBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="1" />
        </Style>
        <Style Selector="ToggleButton.theme-mode-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapMutedTextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.theme-mode-button.start">
            <Setter Property="CornerRadius" Value="4,0,0,4" />
        </Style>
        <Style Selector="ToggleButton.theme-mode-button.middle">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="ToggleButton.theme-mode-button.end">
            <Setter Property="CornerRadius" Value="0,4,4,0" />
        </Style>
        <Style Selector="ToggleButton.theme-mode-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource TokenMapControlHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="ToggleButton.theme-mode-button:checked">
            <Setter Property="Background" Value="{DynamicResource TokenMapAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="Border.theme-mode-divider">
            <Setter Property="Background" Value="{DynamicResource TokenMapBorderBrush}" />
            <Setter Property="Width" Value="1" />
        </Style>
        <Style Selector="Viewbox.theme-mode-icon-host">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="Path.theme-mode-icon">
            <Setter Property="Stroke" Value="{DynamicResource TokenMapMutedTextBrush}" />
            <Setter Property="StrokeThickness" Value="1.6" />
            <Setter Property="StrokeLineCap" Value="Round" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="ToggleButton.theme-mode-button:pointerover Path.theme-mode-icon">
            <Setter Property="Stroke" Value="{DynamicResource TokenMapTextBrush}" />
        </Style>
        <Style Selector="ToggleButton.theme-mode-button:checked Path.theme-mode-icon">
            <Setter Property="Stroke" Value="White" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto"
          Margin="10">
        <Border Name="ToolbarHost"
                Grid.Row="0"
                Classes="panel"
                Padding="10">
            <Grid>
                <StackPanel HorizontalAlignment="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <Button Name="OpenFolderButton"
                                Classes="action-button primary"
                                Content="Open Folder"
                                Command="{Binding Toolbar.OpenFolderCommand}" />
                        <Button Name="RescanButton"
                                Classes="action-button"
                                Content="Rescan"
                                Command="{Binding Toolbar.RescanCommand}" />
                        <Button Name="CancelButton"
                                Classes="action-button"
                                Content="Cancel"
                                Command="{Binding Toolbar.CancelCommand}" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Center"
                                Spacing="2">
                        <TextBlock Foreground="{DynamicResource TokenMapMutedTextBrush}"
                                   FontSize="11"
                                   Text="Selected folder" />
                        <TextBlock FontSize="13"
                                    FontWeight="Medium"
                                   Text="{Binding Toolbar.SelectedFolderDisplay}" />
                    </StackPanel>
                </StackPanel>

                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      ColumnDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="18">
                    <Border Classes="summary-card"
                            MinWidth="120">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="summary-label"
                                       Text="Tokens" />
                            <TextBlock Name="TokenSummaryValueText"
                                       Classes="summary-value"
                                       Text="{Binding Summary.TokenSummaryValue}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            Classes="summary-card"
                            MinWidth="120">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="summary-label"
                                       Text="Lines" />
                            <TextBlock Name="LineSummaryValueText"
                                       Classes="summary-value"
                                       Text="{Binding Summary.LineSummaryValue}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2"
                            Classes="summary-card"
                            MinWidth="120">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="summary-label"
                                       Text="Files" />
                            <TextBlock Name="FileSummaryValueText"
                                       Classes="summary-value"
                                       Text="{Binding Summary.FileSummaryValue}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Button Name="SettingsButton"
                        Classes="action-button"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Content="Settings"
                        Command="{Binding ToggleSettingsCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid Name="WorkspaceHost"
                  Margin="0,10,0,8"
                  ColumnDefinitions="2*,10,3*">
                <Border Name="ProjectTreePane"
                        Grid.Column="0"
                        Classes="panel">
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="8">
                        <TextBlock Classes="panel-title"
                                   Text="Project Tree" />
                        <DataGrid Name="ProjectTreeTable"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding Tree.VisibleNodes}"
                                  SelectedItem="{Binding Tree.SelectedNode, Mode=TwoWay}"
                                  DoubleTapped="ProjectTreeTable_OnDoubleTapped"
                                  PointerPressed="ProjectTreeTable_OnPointerPressed">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Name"
                                                        SortMemberPath="Name"
                                                        Width="3*">
                                    <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:DataType="vm:ProjectTreeNodeViewModel">
                                        <Grid Margin="{Binding IndentMargin}"
                                              ColumnDefinitions="18,18,*"
                                              ColumnSpacing="6">
                                            <Button Grid.Column="0"
                                                    Classes="tree-expander"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Click="ProjectTreeExpandCollapseButton_OnClick"
                                                    IsVisible="{Binding HasChildren}">
                                                <Path Classes="tree-expander-chevron"
                                                      Data="{Binding ExpanderPathData}" />
                                            </Button>
                                            <svg:Svg Grid.Column="1"
                                                     Classes="tree-file-icon"
                                                     Path="{Binding IconPath}" />
                                            <TextBlock Grid.Column="2"
                                                       Classes="tree-table-name"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Name}" />
                                        </Grid>
                                    </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Size"
                                                        SortMemberPath="Size"
                                                        Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:ProjectTreeNodeViewModel">
                                            <TextBlock Classes="tree-table-number"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding SizeText}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Lines"
                                                        SortMemberPath="Lines"
                                                        Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:ProjectTreeNodeViewModel">
                                            <TextBlock Classes="tree-table-number"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding TotalLinesText}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Tokens"
                                                        SortMemberPath="Tokens"
                                                        Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:ProjectTreeNodeViewModel">
                                            <TextBlock Classes="tree-table-number"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding TokensText}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Files"
                                                        SortMemberPath="Files"
                                                        Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="vm:ProjectTreeNodeViewModel">
                                            <TextBlock Classes="tree-table-number"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding FilesText}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              ResizeDirection="Columns"
                              Background="{DynamicResource TokenMapDividerBrush}" />

                <Border Name="TreemapPane"
                        Grid.Column="2"
                        Classes="panel">
                    <Grid RowDefinitions="Auto,*"
                          RowSpacing="8">
                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="10">
                            <TextBlock Classes="panel-title"
                                       VerticalAlignment="Center"
                                       Text="Treemap" />
                            <ItemsControl Name="TreemapBreadcrumbsItemsControl"
                                          Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          ItemsSource="{Binding TreemapBreadcrumbs}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TreemapBreadcrumbItemViewModel">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="0">
                                            <Button Classes="breadcrumb-link"
                                                    IsVisible="{Binding CanNavigate}"
                                                    Content="{Binding Label}"
                                                    Command="{Binding #RootWindow.DataContext.NavigateToTreemapBreadcrumbCommand}"
                                                    CommandParameter="{Binding Node}" />
                                            <TextBlock Classes="breadcrumb-current"
                                                       IsVisible="{Binding IsCurrent}"
                                                       Text="{Binding Label}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                        <Border Grid.Row="1"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="0"
                                Padding="0">
                            <controls:TreemapControl Name="ProjectTreemapControl"
                                                     RootNode="{Binding TreemapRootNode}"
                                                     Metric="{Binding Toolbar.SelectedMetric}"
                                                     SelectedNode="{Binding SelectedNode, Mode=TwoWay}" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Name="SettingsDrawer"
                    ZIndex="1"
                    Classes="panel settings-drawer"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Margin="0,10,0,8"
                    IsVisible="{Binding IsSettingsOpen}">
                <Grid RowDefinitions="Auto,*,Auto"
                      RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <TextBlock Classes="panel-title"
                                   VerticalAlignment="Center"
                                   Text="Settings" />
                        <Button Grid.Column="1"
                                Classes="close-button"
                                VerticalAlignment="Center"
                                Command="{Binding ToggleSettingsCommand}">
                            <Path Classes="close-button-icon"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Data="M 1 1 L 9 9 M 9 1 L 1 9"
                                  IsHitTestVisible="False" />
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="12">
                            <Border Classes="toolbar-group">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="toolbar-group-title"
                                               Text="View" />
                                    <StackPanel Spacing="4">
                                        <TextBlock Foreground="{DynamicResource TokenMapMutedTextBrush}"
                                                   FontSize="11"
                                                   Text="Treemap metric" />
                                        <ComboBox Name="MetricComboBox"
                                                  ItemsSource="{Binding Toolbar.MetricOptions}"
                                                  SelectedItem="{Binding Toolbar.SelectedMetric}"
                                                  IsEnabled="{Binding Toolbar.CanChangeMetric}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Classes="toolbar-group">
                                <StackPanel Spacing="10">
                                    <TextBlock Classes="toolbar-group-title"
                                               Text="Scan" />
                                    <StackPanel Spacing="4">
                                        <TextBlock Foreground="{DynamicResource TokenMapMutedTextBrush}"
                                                   FontSize="11"
                                                   Text="Tokenizer" />
                                        <ComboBox Name="TokenizerComboBox"
                                                  ItemsSource="{Binding Toolbar.TokenProfiles}"
                                                  SelectedItem="{Binding Toolbar.SelectedTokenProfile}"
                                                  IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                                    </StackPanel>

                                    <CheckBox Name="RespectGitIgnoreCheckBox"
                                              Content="Respect .gitignore"
                                              IsChecked="{Binding Toolbar.RespectGitIgnore}"
                                              IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                                    <CheckBox Name="RespectIgnoreCheckBox"
                                              Content="Respect .ignore"
                                              IsChecked="{Binding Toolbar.RespectIgnore}"
                                              IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                                    <CheckBox Name="UseDefaultExcludesCheckBox"
                                              Content="Use default excludes"
                                              IsChecked="{Binding Toolbar.UseDefaultExcludes}"
                                              IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Padding="0">
                        <Grid RowDefinitions="Auto,Auto"
                              RowSpacing="8">
                            <TextBlock Classes="toolbar-group-title"
                                       Text="Theme" />
                            <Border Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Classes="theme-switcher-panel">
                                <Grid ColumnDefinitions="*,Auto,*,Auto,*">
                                    <ToggleButton Name="ThemeLightButton"
                                                  Classes="theme-mode-button start"
                                                  IsChecked="{Binding Toolbar.IsLightThemeSelected, Mode=OneWay}"
                                                  Command="{Binding Toolbar.SelectThemePreferenceCommand}"
                                                  CommandParameter="Light">
                                        <Viewbox Classes="theme-mode-icon-host">
                                            <Canvas Width="20"
                                                    Height="20">
                                                <Path Classes="theme-mode-icon"
                                                      Data="M 10 5.75 A 4.25 4.25 0 1 0 10 14.25 A 4.25 4.25 0 1 0 10 5.75 M 10 2.25 L 10 4 M 10 16 L 10 17.75 M 2.25 10 L 4 10 M 16 10 L 17.75 10 M 4.5 4.5 L 5.8 5.8 M 14.2 14.2 L 15.5 15.5 M 4.5 15.5 L 5.8 14.2 M 14.2 5.8 L 15.5 4.5" />
                                            </Canvas>
                                        </Viewbox>
                                    </ToggleButton>
                                    <Border Grid.Column="1"
                                            Classes="theme-mode-divider" />
                                    <ToggleButton Name="ThemeSystemButton"
                                                  Grid.Column="2"
                                                  Classes="theme-mode-button middle"
                                                  IsChecked="{Binding Toolbar.IsSystemThemeSelected, Mode=OneWay}"
                                                  Command="{Binding Toolbar.SelectThemePreferenceCommand}"
                                                  CommandParameter="System">
                                        <Viewbox Classes="theme-mode-icon-host">
                                            <Canvas Width="20"
                                                    Height="20">
                                                <Path Classes="theme-mode-icon"
                                                      Data="M 3.5 4.5 H 16.5 M 4.75 4.5 H 15.25 A 1.25 1.25 0 0 1 16.5 5.75 V 12 A 1.25 1.25 0 0 1 15.25 13.25 H 4.75 A 1.25 1.25 0 0 1 3.5 12 V 5.75 A 1.25 1.25 0 0 1 4.75 4.5 M 7.5 15.5 H 12.5 M 10 13.25 V 15.5" />
                                            </Canvas>
                                        </Viewbox>
                                    </ToggleButton>
                                    <Border Grid.Column="3"
                                            Classes="theme-mode-divider" />
                                    <ToggleButton Name="ThemeDarkButton"
                                                  Grid.Column="4"
                                                  Classes="theme-mode-button end"
                                                  IsChecked="{Binding Toolbar.IsDarkThemeSelected, Mode=OneWay}"
                                                  Command="{Binding Toolbar.SelectThemePreferenceCommand}"
                                                  CommandParameter="Dark">
                                        <Viewbox Classes="theme-mode-icon-host">
                                            <Canvas Width="20"
                                                    Height="20">
                                                <Path Classes="theme-mode-icon"
                                                      Data="M 11.75 2.5 A 7 7 0 1 0 11.75 17.5 A 5.25 5.25 0 1 1 11.75 2.5" />
                                            </Canvas>
                                        </Viewbox>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Name="StatusStrip"
                Grid.Row="2"
                IsVisible="{Binding Summary.IsProgressVisible}">
            <ProgressBar Name="StatusProgressBar"
                         Foreground="{DynamicResource TokenMapAccentBrush}"
                         Height="4"
                         Minimum="0"
                         Maximum="100"
                         IsIndeterminate="{Binding Summary.IsProgressIndeterminate}"
                         Value="{Binding Summary.ProgressValue}" />
        </Border>
    </Grid>
</Window>
