<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:controls="using:Clever.TokenMap.Treemap"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Clever.TokenMap.App.ViewModels"
             x:Class="Clever.TokenMap.App.Views.ShareCardPreviewView"
             x:DataType="vm:ShareSnapshotViewModel"
             Width="600"
             Height="336">
    <Border Name="ShareCardRoot"
            Width="600"
            Height="336"
            Background="{DynamicResource TokenMapShareCardBackgroundBrush}">

        <Border Name="RoundedCardLayout"
                CornerRadius="24"
                ClipToBounds="True">

            <Grid>
                <Ellipse Width="220"
                         Height="220"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Margin="0,-36,-20,0"
                         IsHitTestVisible="False"
                         Fill="{DynamicResource TokenMapShareCardGlowBrush}" />

                <Border Margin="12"
                        CornerRadius="18"
                        BorderBrush="{DynamicResource TokenMapShareCardBorderBrush}"
                        BorderThickness="1" />

                <Grid Margin="24,0,18,0"
                      ColumnDefinitions="248,14,*">
                    <Grid Margin="0,18,0,18"
                          RowDefinitions="Auto,*,Auto">
                        <StackPanel Spacing="10">
                            <StackPanel Name="ShareTopSectionWithProjectName"
                                        Spacing="10"
                                        IsVisible="{Binding ShowProjectName}">
                                <TextBlock Name="ShareProjectTitleText"
                                           MaxWidth="248"
                                           FontSize="30"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TokenMapShareCardPrimaryTextBrush}"
                                           Text="{Binding DisplayProjectName}"
                                           TextTrimming="CharacterEllipsis" />

                                <StackPanel Spacing="4">
                                    <Grid Name="ShareTokenValueHost"
                                          Width="236"
                                          HorizontalAlignment="Left">
                                        <Viewbox Stretch="Uniform"
                                                 StretchDirection="DownOnly"
                                                 HorizontalAlignment="Left">
                                            <TextBlock Name="ShareTokenValueText"
                                                       FontSize="68"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TokenMapShareCardValueTextBrush}"
                                                       Text="{Binding TokenValue}" />
                                        </Viewbox>
                                    </Grid>
                                    <TextBlock Margin="2,0,0,0"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TokenMapShareCardSecondaryTextBrush}"
                                               Text="tokens" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Name="ShareTopSectionWithoutProjectName"
                                        Spacing="4"
                                        IsVisible="{Binding ShowProjectNamePlaceholder}">
                                <Border Height="18"
                                        Background="Transparent"
                                        IsHitTestVisible="False" />
                                <Grid Name="ShareTokenValueHostWithoutProjectName"
                                      Width="236"
                                      HorizontalAlignment="Left">
                                        <Viewbox Stretch="Uniform"
                                             StretchDirection="DownOnly"
                                             HorizontalAlignment="Left">
                                        <TextBlock Name="ShareTokenValueTextWithoutProjectName"
                                                   FontSize="68"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TokenMapShareCardValueTextBrush}"
                                                   Text="{Binding TokenValue}" />
                                    </Viewbox>
                                </Grid>
                                <TextBlock Margin="2,0,0,0"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TokenMapShareCardSecondaryTextBrush}"
                                           Text="tokens" />
                            </StackPanel>

                            <Border Width="232"
                                    Height="1"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource TokenMapShareCardDividerBrush}" />

                            <Grid Name="ShareSecondaryMetricsGrid"
                                  Width="232">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="102" />
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="102" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <Grid Name="ShareLineValueHost"
                                          HorizontalAlignment="Stretch">
                                        <Viewbox Stretch="Uniform"
                                                 StretchDirection="DownOnly"
                                                 HorizontalAlignment="Left">
                                            <TextBlock Name="ShareLineValueText"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TokenMapShareCardPrimaryTextBrush}"
                                                       Text="{Binding LineValue}" />
                                        </Viewbox>
                                    </Grid>
                                    <TextBlock FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TokenMapShareCardSecondaryTextBrush}"
                                               Text="lines" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Width="1"
                                        Height="42"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource TokenMapShareCardDividerBrush}" />

                                <StackPanel Grid.Column="2"
                                            Spacing="2">
                                    <Grid Name="ShareFileValueHost"
                                          HorizontalAlignment="Stretch">
                                        <Viewbox Stretch="Uniform"
                                                 StretchDirection="DownOnly"
                                                 HorizontalAlignment="Left">
                                            <TextBlock Name="ShareFileValueText"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TokenMapShareCardPrimaryTextBrush}"
                                                       Text="{Binding FileValue}" />
                                        </Viewbox>
                                    </Grid>
                                    <TextBlock FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TokenMapShareCardSecondaryTextBrush}"
                                               Text="files" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,2"
                                    VerticalAlignment="Bottom"
                                    Spacing="8">
                            <TextBlock Margin="0,1,0,0"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TokenMapShareCardFooterLeadBrush}"
                                       Text="make your own:" />
                            <StackPanel Orientation="Horizontal"
                                        Spacing="4">
                                <Path Width="12"
                                      Height="12"
                                      Margin="0,2,0,0"
                                      Stretch="Uniform"
                                      Fill="{DynamicResource TokenMapShareCardFooterIconBrush}"
                                      Data="{StaticResource TokenMapGithub16Geometry}" />
                                <TextBlock FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TokenMapShareCardFooterLinkBrush}"
                                           Text="etechlead/token-map" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Column="2"
                            Margin="0,18,0,18"
                            VerticalAlignment="Stretch"
                            Background="Transparent"
                            CornerRadius="18"
                            ClipToBounds="True">
                        <controls:TreemapControl Name="RoundedShareTreemapControl"
                                                 Margin="0"
                                                 IsHitTestVisible="False"
                                                 Focusable="False"
                                                 CanvasBackgroundBrush="Transparent"
                                                 CanvasInset="3"
                                                 RootNode="{Binding PreviewRootNode}"
                                                 Metric="{Binding TreemapMetric}"
                                                 Palette="{Binding PreviewTreemapPalette}"
                                                 ShowLabels="False"
                                                 ShowDirectoryNodes="False"
                                                 ShowLeafBorders="False"
                                                 LeafCornerRadius="6"
                                                 LeafGap="2"
                                                 MinLeafAreaRatio="0.0018" />
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Border>
</UserControl>
