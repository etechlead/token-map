<UserControl xmlns="https://github.com/avaloniaui"
              xmlns:controls="using:Clever.TokenMap.Treemap"
             xmlns:state="using:Clever.TokenMap.App.State"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:vm="using:Clever.TokenMap.App.ViewModels"
             x:Class="Clever.TokenMap.App.Views.Sections.TreemapPaneView"
             x:Name="TreemapPaneRoot"
             x:DataType="vm:MainWindowViewModel">
    <Border Name="TreemapPane"
            Classes="panel treemap-pane">
        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="6">
            <Grid Name="TreemapHeader"
                  Margin="6,12,6,0"
                  ColumnDefinitions="Auto,Auto,Auto,*"
                  ColumnSpacing="12">
                <TextBlock Classes="panel-title"
                           Name="TreemapTitleText"
                           VerticalAlignment="Center"
                           Text="Treemap" />
                <Border Grid.Column="1"
                        Classes="segmented-toggle-panel treemap-metric-switcher"
                        VerticalAlignment="Center"
                        IsVisible="{Binding Toolbar.ShowTreemapMetricButtons}">
                    <ItemsControl Name="TreemapMetricButtonsItemsControl"
                                  ItemsSource="{Binding Toolbar.VisibleTreemapMetricOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MetricSelectionOptionViewModel">
                                <Grid ColumnDefinitions="Auto,*">
                                    <Border Classes="segmented-toggle-divider"
                                            IsVisible="{Binding ShowLeadingDivider}" />
                                    <ToggleButton Grid.Column="1"
                                                  Classes="segmented-toggle-button treemap-metric-button"
                                                  Classes.start="{Binding IsFirst}"
                                                  Classes.middle="{Binding IsMiddle}"
                                                  Classes.end="{Binding IsLast}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  IsEnabled="{Binding #TreemapPaneRoot.DataContext.Toolbar.CanChangeMetric}"
                                                  Content="{Binding Label}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
                <ComboBox Name="TreemapMetricComboBox"
                          Grid.Column="1"
                          Width="180"
                          VerticalAlignment="Center"
                          IsVisible="{Binding Toolbar.ShowTreemapMetricSelector}"
                          IsEnabled="{Binding Toolbar.CanChangeMetric}"
                          ItemsSource="{Binding Toolbar.VisibleTreemapMetricOptions}"
                          SelectedItem="{Binding Toolbar.SelectedTreemapMetricOption, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:MetricSelectionOptionViewModel">
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <CheckBox Grid.Column="2"
                          Name="TreemapShowValuesCheckBox"
                          VerticalAlignment="Center"
                          IsChecked="{Binding Toolbar.ShowTreemapMetricValues, Mode=TwoWay}"
                          IsEnabled="{Binding Toolbar.CanChangeMetric}"
                          Content="Show values" />
                <ItemsControl Name="TreemapBreadcrumbsItemsControl"
                              Grid.Column="3"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding TreemapBreadcrumbs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="state:TreemapBreadcrumbItem">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="0">
                                <Button Classes="breadcrumb-link"
                                        IsVisible="{Binding CanNavigate}"
                                        Content="{Binding Label}"
                                        Command="{Binding #TreemapPaneRoot.DataContext.NavigateToTreemapBreadcrumbCommand}"
                                        CommandParameter="{Binding Node}" />
                                <TextBlock Classes="breadcrumb-current"
                                           IsVisible="{Binding IsCurrent}"
                                           Text="{Binding Label}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
            <Grid Grid.Row="1">
                <controls:TreemapControl Name="ProjectTreemapControl"
                                         RootNode="{Binding TreemapRootNode}"
                                         Metric="{Binding Toolbar.SelectedMetric}"
                                         MinimumVisibleWeight="{Binding TreemapThresholdValue}"
                                         VisibleMetricIds="{Binding Toolbar.VisibleMetricIds}"
                                         Palette="{Binding Toolbar.SelectedTreemapPalette}"
                                         ShowMetricValues="{Binding Toolbar.ShowTreemapMetricValues}"
                                         SelectedNode="{Binding SelectedNode, Mode=TwoWay}" />
                <controls:TreemapTooltipOverlay IsHitTestVisible="False"
                                                Target="{Binding #ProjectTreemapControl}" />
            </Grid>
            <Grid Grid.Row="2"
                  Name="TreemapThresholdPanel"
                  Margin="6,1,6,0"
                  RowDefinitions="Auto,Auto"
                  ColumnDefinitions="Auto,*,Auto"
                  RowSpacing="0"
                  ColumnSpacing="8"
                  IsVisible="{Binding HasSnapshot}">
                <TextBlock Grid.Row="0"
                           VerticalAlignment="Center"
                           Classes="panel-body treemap-threshold-label"
                           Text="Threshold" />
                <Slider Name="TreemapThresholdSlider"
                        Classes="treemap-threshold-slider"
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        VerticalAlignment="Center"
                        Minimum="{Binding TreemapThresholdSliderMinimum}"
                        Maximum="{Binding TreemapThresholdSliderMaximum}"
                        Value="{Binding TreemapThresholdSliderValue, Mode=TwoWay}"
                        IsEnabled="{Binding CanAdjustTreemapThreshold}">
                    <Slider.Resources>
                        <x:Double x:Key="SliderHorizontalHeight">22</x:Double>
                        <x:Double x:Key="SliderHorizontalThumbWidth">14</x:Double>
                        <x:Double x:Key="SliderHorizontalThumbHeight">14</x:Double>
                        <CornerRadius x:Key="SliderThumbCornerRadius">7</CornerRadius>
                    </Slider.Resources>
                </Slider>
                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Name="TreemapThresholdValueText"
                           MinWidth="52"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           TextAlignment="Right"
                           Classes="panel-body treemap-threshold-value"
                           Text="{Binding TreemapThresholdValueText}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
