<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Clever.TokenMap.App.ViewModels"
             x:Class="Clever.TokenMap.App.Views.Sections.SettingsDrawerView"
             x:DataType="vm:MainWindowViewModel">
    <Border Name="SettingsDrawer"
            Classes="panel settings-drawer"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            Margin="0,10,0,8"
            IsVisible="{Binding IsSettingsOpen}">
        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <TextBlock Classes="panel-title"
                           VerticalAlignment="Center"
                           Text="Settings" />
                <Button Grid.Column="1"
                        Classes="close-button"
                        VerticalAlignment="Center"
                        Command="{Binding CloseSettingsCommand}"
                        ToolTip.Tip="Close settings">
                    <Path Classes="close-button-icon"
                          Data="{StaticResource FluentDismiss20Geometry}" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <Border Classes="toolbar-group">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="toolbar-group-title"
                                       Text="View" />
                            <StackPanel Spacing="4">
                                <TextBlock Foreground="{DynamicResource TokenMapMutedTextBrush}"
                                           FontSize="11"
                                           Text="Treemap palette" />
                                <StackPanel Spacing="4">
                                    <RadioButton Name="TreemapPaletteWeightedRadioButton"
                                                 GroupName="TreemapPalette"
                                                 Content="Weighted"
                                                 IsChecked="{Binding Toolbar.IsWeightedTreemapPaletteSelected, Mode=TwoWay}" />
                                    <RadioButton Name="TreemapPaletteStudioRadioButton"
                                                 GroupName="TreemapPalette"
                                                 Content="Studio"
                                                 IsChecked="{Binding Toolbar.IsStudioTreemapPaletteSelected, Mode=TwoWay}" />
                                    <RadioButton Name="TreemapPaletteClassicRadioButton"
                                                 GroupName="TreemapPalette"
                                                 Content="Classic"
                                                 IsChecked="{Binding Toolbar.IsClassicTreemapPaletteSelected, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Classes="toolbar-group">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="toolbar-group-title"
                                       Text="Scan" />
                            <CheckBox Name="RespectGitIgnoreCheckBox"
                                      Content="Respect .gitignore"
                                      IsChecked="{Binding Toolbar.RespectGitIgnore}"
                                      IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <CheckBox Name="UseGlobalExcludesCheckBox"
                                              Content="Use global excludes"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding Toolbar.UseGlobalExcludes}"
                                              IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                                    <Button Name="EditGlobalExcludesButton"
                                            Grid.Column="1"
                                            Classes="action-button"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Padding="10,4"
                                            MinHeight="28"
                                            Command="{Binding ExcludesEditor.OpenGlobalCommand}"
                                            Content="Edit"
                                            IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                                </Grid>
                                <Border Name="CurrentFolderSettingsDivider"
                                        Height="1"
                                        Margin="0,4,0,2"
                                        Background="{DynamicResource TokenMapDividerBrush}"
                                        IsVisible="{Binding Toolbar.HasCurrentFolderSettings}" />
                                <StackPanel Name="CurrentFolderSettingsPanel"
                                            Spacing="6"
                                            IsVisible="{Binding Toolbar.HasCurrentFolderSettings}">
                                    <TextBlock Name="CurrentFolderSettingsTitle"
                                               Classes="toolbar-group-title"
                                               Text="{Binding Toolbar.CurrentFolderSettingsTitle}" />
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">
                                        <CheckBox Name="UseFolderExcludesCheckBox"
                                                  Content="Use folder excludes"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding Toolbar.UseFolderExcludes}"
                                                  IsEnabled="{Binding Toolbar.CanConfigureFolderExcludes}" />
                                        <Button Name="EditFolderExcludesButton"
                                                Grid.Column="1"
                                                Classes="action-button"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                Padding="10,4"
                                                MinHeight="28"
                                                Command="{Binding ExcludesEditor.OpenFolderCommand}"
                                                Content="Edit"
                                                IsEnabled="{Binding Toolbar.CanConfigureFolderExcludes}" />
                                    </Grid>
                                </StackPanel>
                                <Border Name="ScanSettingsRescanNotice"
                                        Classes="settings-notice-panel"
                                        IsVisible="{Binding ExcludesEditor.ShowRescanNotice}">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">
                                        <TextBlock Name="ScanSettingsRescanNoticeText"
                                                   Classes="settings-notice-text"
                                                   VerticalAlignment="Center"
                                                   Text="Scan settings updated. Rescan to apply." />
                                        <Button Name="ScanSettingsRescanButton"
                                                Grid.Column="1"
                                                Classes="settings-link"
                                                VerticalAlignment="Center"
                                                Command="{Binding Toolbar.RescanCommand}"
                                                Content="Rescan now" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Padding="0">
                <Grid RowDefinitions="Auto,Auto"
                      RowSpacing="8">
                    <TextBlock Classes="toolbar-group-title"
                               Text="Theme" />
                    <Border Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Classes="segmented-toggle-panel">
                        <Grid ColumnDefinitions="*,Auto,*,Auto,*">
                            <ToggleButton Name="ThemeLightButton"
                                          Classes="theme-mode-button segmented-toggle-button start"
                                          IsChecked="{Binding Toolbar.IsLightThemeSelected, Mode=OneWay}"
                                          Command="{Binding Toolbar.SelectLightThemePreferenceCommand}"
                                          ToolTip.Tip="Use the light theme">
                                <Viewbox Classes="theme-mode-icon-host">
                                    <Grid Width="20"
                                          Height="20">
                                        <Path Classes="theme-mode-icon theme-mode-icon-regular"
                                              Data="{StaticResource FluentBrightnessHigh20RegularGeometry}" />
                                        <Path Classes="theme-mode-icon theme-mode-icon-filled"
                                              Data="{StaticResource FluentBrightnessHigh20FilledGeometry}" />
                                    </Grid>
                                </Viewbox>
                            </ToggleButton>
                            <Border Grid.Column="1"
                                    Classes="segmented-toggle-divider" />
                            <ToggleButton Name="ThemeSystemButton"
                                          Grid.Column="2"
                                          Classes="theme-mode-button segmented-toggle-button middle"
                                          IsChecked="{Binding Toolbar.IsSystemThemeSelected, Mode=OneWay}"
                                          Command="{Binding Toolbar.SelectSystemThemePreferenceCommand}"
                                          ToolTip.Tip="Follow the system theme">
                                <Viewbox Classes="theme-mode-icon-host">
                                    <Grid Width="20"
                                          Height="20">
                                        <Path Classes="theme-mode-icon theme-mode-icon-regular"
                                              Data="{StaticResource FluentDesktopMac20RegularGeometry}" />
                                        <Path Classes="theme-mode-icon theme-mode-icon-filled"
                                              Data="{StaticResource FluentDesktopMac20FilledGeometry}" />
                                    </Grid>
                                </Viewbox>
                            </ToggleButton>
                            <Border Grid.Column="3"
                                    Classes="segmented-toggle-divider" />
                            <ToggleButton Name="ThemeDarkButton"
                                          Grid.Column="4"
                                          Classes="theme-mode-button segmented-toggle-button end"
                                          IsChecked="{Binding Toolbar.IsDarkThemeSelected, Mode=OneWay}"
                                          Command="{Binding Toolbar.SelectDarkThemePreferenceCommand}"
                                          ToolTip.Tip="Use the dark theme">
                                <Viewbox Classes="theme-mode-icon-host">
                                    <Grid Width="20"
                                          Height="20">
                                        <Path Classes="theme-mode-icon theme-mode-icon-regular"
                                              Data="{StaticResource FluentDarkTheme20RegularGeometry}" />
                                        <Path Classes="theme-mode-icon theme-mode-icon-filled"
                                              Data="{StaticResource FluentDarkTheme20FilledGeometry}" />
                                    </Grid>
                                </Viewbox>
                            </ToggleButton>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
