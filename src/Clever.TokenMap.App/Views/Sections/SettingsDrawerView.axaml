<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             xmlns:state="using:Clever.TokenMap.App.State"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Clever.TokenMap.App.ViewModels"
             x:Class="Clever.TokenMap.App.Views.Sections.SettingsDrawerView"
             x:DataType="vm:MainWindowViewModel">
    <Border Name="SettingsDrawer"
            Classes="panel settings-drawer"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            Margin="0,10,0,8"
            IsVisible="{Binding IsSettingsOpen}">
        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <TextBlock Classes="panel-title"
                           VerticalAlignment="Center"
                           Text="{Binding Localization.Settings}" />
                <Button Grid.Column="1"
                        Classes="close-button"
                        VerticalAlignment="Center"
                        Command="{Binding CloseSettingsCommand}"
                        ToolTip.Tip="{Binding Localization.CloseSettingsTooltip}">
                    <Path Classes="close-button-icon"
                          Data="{StaticResource FluentDismiss20Geometry}" />
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <Border Classes="toolbar-group">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="toolbar-group-title"
                                       Text="{Binding Localization.View}" />
                            <StackPanel Spacing="4">
                                <TextBlock Foreground="{DynamicResource TokenMapMutedTextBrush}"
                                           FontSize="11"
                                           Text="{Binding Localization.TreemapPalette}" />
                                <StackPanel Spacing="4">
                                    <RadioButton Name="TreemapPaletteWeightedRadioButton"
                                                 GroupName="TreemapPalette"
                                                 Content="{Binding Localization.TreemapPaletteWeighted}"
                                                 IsChecked="{Binding Toolbar.IsWeightedTreemapPaletteSelected, Mode=TwoWay}" />
                                    <RadioButton Name="TreemapPaletteStudioRadioButton"
                                                 GroupName="TreemapPalette"
                                                 Content="{Binding Localization.TreemapPaletteStudio}"
                                                 IsChecked="{Binding Toolbar.IsStudioTreemapPaletteSelected, Mode=TwoWay}" />
                                    <RadioButton Name="TreemapPalettePlainRadioButton"
                                                 GroupName="TreemapPalette"
                                                 Content="{Binding Localization.TreemapPalettePlain}"
                                                 IsChecked="{Binding Toolbar.IsPlainTreemapPaletteSelected, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Classes="toolbar-group">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="toolbar-group-title"
                                       Text="{Binding Localization.Metrics}" />
                            <ItemsControl Name="TreemapMetricsItemsControl"
                                          ItemsSource="{Binding Toolbar.MetricVisibilityOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MetricVisibilityOptionViewModel">
                                        <CheckBox Content="{Binding Label}"
                                                  IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsToggleEnabled}"
                                                  ToolTip.Tip="{Binding Description}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Name="TreeOnlyMetricsLegendPanel"
                                  ColumnDefinitions="*,Auto,*"
                                  ColumnSpacing="8"
                                  IsVisible="{Binding Toolbar.HasTreeOnlyMetricVisibilityOptions}">
                                <Border Name="TreeOnlyMetricsLegendLeft"
                                        Height="1"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource TokenMapDividerBrush}" />
                                <TextBlock Name="TreeOnlyMetricsLegendText"
                                           Grid.Column="1"
                                           Classes="toolbar-group-title"
                                           VerticalAlignment="Center"
                                           Text="{Binding Localization.TreeOnly}" />
                                <Border Name="TreeOnlyMetricsLegendRight"
                                        Grid.Column="2"
                                        Height="1"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource TokenMapDividerBrush}" />
                            </Grid>
                            <ItemsControl Name="TreeOnlyMetricsItemsControl"
                                          IsVisible="{Binding Toolbar.HasTreeOnlyMetricVisibilityOptions}"
                                          ItemsSource="{Binding Toolbar.TreeOnlyMetricVisibilityOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MetricVisibilityOptionViewModel">
                                        <CheckBox Content="{Binding Label}"
                                                  IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsToggleEnabled}"
                                                  ToolTip.Tip="{Binding Description}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid ColumnDefinitions="Auto,Auto,*"
                                  ColumnSpacing="8">
                                <Button Name="MetricsResetDefaultsButton"
                                        Classes="action-button"
                                        Padding="10,4"
                                        MinHeight="28"
                                        Command="{Binding Toolbar.ResetVisibleMetricIdsCommand}"
                                        Content="{Binding Localization.ResetDefaults}" />
                                <Button Name="MetricsShowAllButton"
                                        Grid.Column="1"
                                        Classes="action-button"
                                        Padding="10,4"
                                        MinHeight="28"
                                        Command="{Binding Toolbar.ShowAllMetricIdsCommand}"
                                        Content="{Binding Localization.ShowAll}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="toolbar-group">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="toolbar-group-title"
                                       Text="{Binding Localization.Scan}" />
                            <CheckBox Name="RespectGitIgnoreCheckBox"
                                      Content="{Binding Localization.RespectGitIgnore}"
                                      IsChecked="{Binding Toolbar.RespectGitIgnore}"
                                      IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <CheckBox Name="UseGlobalExcludesCheckBox"
                                              Content="{Binding Localization.UseGlobalExcludes}"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding Toolbar.UseGlobalExcludes}"
                                              IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                                    <Button Name="EditGlobalExcludesButton"
                                            Grid.Column="1"
                                            Classes="action-button"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right"
                                            Padding="10,4"
                                            MinHeight="28"
                                            Command="{Binding ExcludesEditor.OpenGlobalCommand}"
                                            Content="{Binding Localization.Edit}"
                                            IsEnabled="{Binding Toolbar.CanConfigureScanOptions}" />
                                </Grid>
                                <Border Name="CurrentFolderSettingsDivider"
                                        Height="1"
                                        Margin="0,4,0,2"
                                        Background="{DynamicResource TokenMapDividerBrush}"
                                        IsVisible="{Binding Toolbar.HasCurrentFolderSettings}" />
                                <StackPanel Name="CurrentFolderSettingsPanel"
                                            Spacing="6"
                                            IsVisible="{Binding Toolbar.HasCurrentFolderSettings}">
                                    <TextBlock Name="CurrentFolderSettingsTitle"
                                               Classes="toolbar-group-title"
                                               Text="{Binding Toolbar.CurrentFolderSettingsTitle}" />
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">
                                        <CheckBox Name="UseFolderExcludesCheckBox"
                                                  Content="{Binding Localization.UseFolderExcludes}"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding Toolbar.UseFolderExcludes}"
                                                  IsEnabled="{Binding Toolbar.CanConfigureFolderExcludes}" />
                                        <Button Name="EditFolderExcludesButton"
                                                Grid.Column="1"
                                                Classes="action-button"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                Padding="10,4"
                                                MinHeight="28"
                                                Command="{Binding ExcludesEditor.OpenFolderCommand}"
                                                Content="{Binding Localization.Edit}"
                                                IsEnabled="{Binding Toolbar.CanConfigureFolderExcludes}" />
                                    </Grid>
                                </StackPanel>
                                <Border Name="ScanSettingsRescanNotice"
                                        Classes="settings-notice-panel"
                                        IsVisible="{Binding ExcludesEditor.ShowRescanNotice}">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">
                                        <TextBlock Name="ScanSettingsRescanNoticeText"
                                                   Classes="settings-notice-text"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding Localization.ScanSettingsUpdatedRescanToApply}" />
                                        <Button Name="ScanSettingsRescanButton"
                                                Grid.Column="1"
                                                Classes="settings-link"
                                                VerticalAlignment="Center"
                                                Command="{Binding Toolbar.RescanCommand}"
                                                Content="{Binding Localization.RescanNow}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Classes="toolbar-group">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="toolbar-group-title"
                                       Text="{Binding Localization.Prompts}" />
                            <Button Name="EditRefactorPromptTemplateButton"
                                    Classes="action-button"
                                    HorizontalAlignment="Left"
                                    Padding="10,4"
                                    MinHeight="28"
                                    Command="{Binding RefactorPromptTemplateSettings.OpenEditorCommand}"
                                    Content="{Binding Localization.EditRefactorPromptTemplate}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Padding="0">
                <StackPanel Spacing="12">
                    <Border Name="AboutCard"
                            Classes="toolbar-group"
                            Padding="12"
                            Margin="0,0,0,32">
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="8">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="8">
                                <svg:Svg Name="AboutAppIcon"
                                         Width="18"
                                         Height="18"
                                         VerticalAlignment="Center"
                                         Path="avares://Clever.TokenMap.App/Assets/app-icon.svg" />
                                <TextBlock Name="AboutProductNameText"
                                           Grid.Column="1"
                                           Classes="about-product-text"
                                           VerticalAlignment="Center"
                                           Text="{Binding About.ProductName}" />
                                <TextBlock Name="AboutVersionText"
                                           Grid.Column="2"
                                           Classes="toolbar-group-title"
                                           VerticalAlignment="Center"
                                           Text="{Binding About.VersionText}"
                                           ToolTip.Tip="{Binding About.InformationalVersion}" />
                            </Grid>

                            <TextBlock Name="AboutDescriptionText"
                                       Grid.Row="1"
                                       Foreground="{DynamicResource TokenMapMutedTextBrush}"
                                       FontSize="11"
                                       Text="{Binding About.Description}" />

                            <Grid Grid.Row="2"
                                  ColumnDefinitions="Auto,*"
                                  ColumnSpacing="12">
                                <Button Name="AboutRepositoryButton"
                                        Classes="about-link-button"
                                        Command="{Binding About.OpenRepositoryCommand}"
                                        ToolTip.Tip="{Binding About.RepositoryUrl}">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6">
                                        <Path Classes="about-link-icon"
                                              Data="{StaticResource TokenMapGithub16Geometry}" />
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="{Binding About.RepositoryDisplayName}" />
                                    </StackPanel>
                                </Button>

                                <TextBlock Name="AboutLicenseText"
                                           Grid.Column="1"
                                           Classes="about-license-text"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Text="{Binding About.LicenseName}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="8">
                        <TextBlock Classes="toolbar-group-title"
                                   Text="{Binding Localization.ApplicationLanguage}" />
                        <ComboBox Name="ApplicationLanguageComboBox"
                                  Grid.Row="1"
                                  Width="180"
                                  ItemsSource="{Binding Toolbar.ApplicationLanguageOptions}"
                                  SelectedItem="{Binding Toolbar.SelectedApplicationLanguageOption, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="state:ApplicationLanguageOption">
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="8">
                        <TextBlock Classes="toolbar-group-title"
                                   Text="{Binding Localization.Theme}" />
                        <Border Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Classes="segmented-toggle-panel">
                            <Grid ColumnDefinitions="*,Auto,*,Auto,*">
                                <ToggleButton Name="ThemeLightButton"
                                              Classes="theme-mode-button segmented-toggle-button start"
                                              IsChecked="{Binding Toolbar.IsLightThemeSelected, Mode=OneWay}"
                                              Command="{Binding Toolbar.SelectLightThemePreferenceCommand}"
                                              ToolTip.Tip="{Binding Localization.UseLightTheme}">
                                    <Viewbox Classes="theme-mode-icon-host">
                                        <Grid Width="20"
                                              Height="20">
                                            <Path Classes="theme-mode-icon theme-mode-icon-regular"
                                                  Data="{StaticResource FluentBrightnessHigh20RegularGeometry}" />
                                            <Path Classes="theme-mode-icon theme-mode-icon-filled"
                                                  Data="{StaticResource FluentBrightnessHigh20FilledGeometry}" />
                                        </Grid>
                                    </Viewbox>
                                </ToggleButton>
                                <Border Grid.Column="1"
                                        Classes="segmented-toggle-divider" />
                                <ToggleButton Name="ThemeSystemButton"
                                              Grid.Column="2"
                                              Classes="theme-mode-button segmented-toggle-button middle"
                                              IsChecked="{Binding Toolbar.IsSystemThemeSelected, Mode=OneWay}"
                                              Command="{Binding Toolbar.SelectSystemThemePreferenceCommand}"
                                              ToolTip.Tip="{Binding Localization.UseSystemTheme}">
                                    <Viewbox Classes="theme-mode-icon-host">
                                        <Grid Width="20"
                                              Height="20">
                                            <Path Classes="theme-mode-icon theme-mode-icon-regular"
                                                  Data="{StaticResource FluentDesktopMac20RegularGeometry}" />
                                            <Path Classes="theme-mode-icon theme-mode-icon-filled"
                                                  Data="{StaticResource FluentDesktopMac20FilledGeometry}" />
                                        </Grid>
                                    </Viewbox>
                                </ToggleButton>
                                <Border Grid.Column="3"
                                        Classes="segmented-toggle-divider" />
                                <ToggleButton Name="ThemeDarkButton"
                                              Grid.Column="4"
                                              Classes="theme-mode-button segmented-toggle-button end"
                                              IsChecked="{Binding Toolbar.IsDarkThemeSelected, Mode=OneWay}"
                                              Command="{Binding Toolbar.SelectDarkThemePreferenceCommand}"
                                              ToolTip.Tip="{Binding Localization.UseDarkTheme}">
                                    <Viewbox Classes="theme-mode-icon-host">
                                        <Grid Width="20"
                                              Height="20">
                                            <Path Classes="theme-mode-icon theme-mode-icon-regular"
                                                  Data="{StaticResource FluentDarkTheme20RegularGeometry}" />
                                            <Path Classes="theme-mode-icon theme-mode-icon-filled"
                                                  Data="{StaticResource FluentDarkTheme20FilledGeometry}" />
                                        </Grid>
                                    </Viewbox>
                                </ToggleButton>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
