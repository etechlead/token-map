<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Clever.TokenMap.App.ViewModels"
             x:Class="Clever.TokenMap.App.Views.Sections.ProjectTreePaneView"
             x:DataType="vm:MainWindowViewModel">
    <Border Name="ProjectTreePane"
            Classes="panel">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="8">
            <TextBlock Classes="panel-title"
                       Text="Project Tree" />
            <DataGrid Name="ProjectTreeTable"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      ItemsSource="{Binding Tree.VisibleNodes}"
                      SelectedItem="{Binding Tree.SelectedNode, Mode=TwoWay}"
                      DoubleTapped="ProjectTreeTable_OnDoubleTapped"
                      PointerPressed="ProjectTreeTable_OnPointerPressed">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Name"
                                            SortMemberPath="Name"
                                            Width="3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:ProjectTreeNodeViewModel">
                                <Grid Margin="{Binding IndentMargin}"
                                      ColumnDefinitions="18,18,*"
                                      ColumnSpacing="6">
                                    <Button Grid.Column="0"
                                            Classes="tree-expander"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Click="ProjectTreeExpandCollapseButton_OnClick"
                                            IsVisible="{Binding HasChildren}">
                                        <Grid Width="10"
                                              Height="10">
                                            <Path Classes="tree-expander-icon"
                                                  Data="{StaticResource FluentChevronRight16Geometry}"
                                                  IsVisible="{Binding IsCollapsed}" />
                                            <Path Classes="tree-expander-icon"
                                                  Data="{StaticResource FluentChevronDown16Geometry}"
                                                  IsVisible="{Binding IsExpanded}" />
                                        </Grid>
                                    </Button>
                                    <svg:Svg Grid.Column="1"
                                             Classes="tree-file-icon"
                                             Path="{Binding IconPath}" />
                                    <TextBlock Grid.Column="2"
                                               Classes="tree-table-name"
                                               VerticalAlignment="Center"
                                               Text="{Binding Name}" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Size"
                                            SortMemberPath="Size"
                                            Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:ProjectTreeNodeViewModel">
                                <TextBlock Classes="tree-table-number"
                                           VerticalAlignment="Center"
                                           Text="{Binding SizeText}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Lines"
                                            SortMemberPath="Lines"
                                            Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:ProjectTreeNodeViewModel">
                                <TextBlock Classes="tree-table-number"
                                           VerticalAlignment="Center"
                                           Text="{Binding TotalLinesText}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Tokens"
                                            SortMemberPath="Tokens"
                                            Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:ProjectTreeNodeViewModel">
                                <TextBlock Classes="tree-table-number"
                                           VerticalAlignment="Center"
                                           Text="{Binding TokensText}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Files"
                                            SortMemberPath="Files"
                                            Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:ProjectTreeNodeViewModel">
                                <TextBlock Classes="tree-table-number"
                                           VerticalAlignment="Center"
                                           Text="{Binding FilesText}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
